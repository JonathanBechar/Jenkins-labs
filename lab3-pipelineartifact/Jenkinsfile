pipeline {
    agent {
        kubernetes {
            yaml '''
                apiVersion: v1
                kind: Pod
                spec:
                    containers:
                        - name: python
                          image: python:3.12-bookworm
                          command:
                              - cat
                          tty: true
            '''
        }
    }

    environment {
        PYENV_HOME = "${WORKSPACE}/welcome/app/flask-volt-dashboard/.pyenv"
        PROJECT_HOME = "${WORKSPACE}/welcome/app/flask-volt-dashboard"
        FLASK_APP = 'run.py'
        FLASK_ENV = 'development'
    }

    stages {
        stage('Clone Flask Project') {
            steps {
                // Use the Git plugin to clone the repository
                git branch: 'jenkins-workshop', url: 'https://github.com/yanivomc/devopshift-welcome.git'
            }
        }

        stage('Debug') {
            steps {
                container('python') {
                    sh '''
                        echo "WORKSPACE=$WORKSPACE"
                        pwd
                        ls -la
                        find . -maxdepth 4 -type d
                    '''
                }
            }
        }
        
        stage('Setup Python Environment and Install Dependencies') {
            steps {
                container('python') {
                    dir("${PROJECT_HOME}") {
                        sh '''#!/bin/bash
                            python3 -m venv $PYENV_HOME
                            . $PYENV_HOME/bin/activate

                            python -m pip install --upgrade pip
                            python -m pip install -r requirements.txt
                        '''
                    }
                }
            }    
        }

        stage('Run Flask Application') {
            steps {
                container('python') {
                    dir("${PROJECT_HOME}") {
                        sh '''
                            echo "Starting Flask application on 0.0.0.0:5001..."

                            nohup .pyenv/bin/flask run \
                            --host=0.0.0.0 \
                            --port=5001 \
                            > flask_app.log 2>&1 &

                            sleep 2

                            if [ ! -f flask_app.log ]; then
                                echo "flask_app.log was not created" > flask_app.log
                            fi

                            ls -la flask_app.log
                        '''

                        archiveArtifacts artifacts: 'flask_app.log', allowEmptyArchive: false
                    }
                }
            }
        }

        stage('Verify Application') {
            steps {
                dir("${PROJECT_HOME}") {
                    script {
                        sleep 10

                        def status = sh(
                            script: "curl -s http://127.0.0.1:5001 > /dev/null",
                            returnStatus: true
                        )

                        if (status != 0) {
                            echo "There is a problem with our flask application - printing log below"
                            sh 'cat flask_app.log || true'
                            error "Flask application is not responding!"
                        }

                        echo "Flask application is running successfully."
                    }
                }
            }
        }

        stage('Manual QA Approval') {
            steps {
                script {
                    def qaResult = input(
                        message: 'Does the QA team approve this deployment?',
                        ok: 'Submit',
                        parameters: [choice(name: 'QA_RESULT', choices: 'APPROVED\nREJECTED', description: 'Choose QA result')]
                    )

                    env.QA_RESULT = qaResult
                }
            }
        }

        stage('QA Decision') {
            steps {
                script {
                    if (env.QA_RESULT == 'REJECTED') {
                        echo 'QA rejected the deployment.'
                        error 'Stopping pipeline because QA rejected the deployment.'
                    }

                    echo 'QA approved the deployment. Pipeline can continue.'
                }
            }
        }
    }

    post {
        always {
            container('python') {
                sh '''
                    echo "Cleaning up virtualenv..."
                    rm -rf "$PYENV_HOME" || true
                '''
            }
        }
    }
}
